{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lethe",
  "version": "1.0.0",
  "identifier": "com.lethe.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lethe",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "decorations": false,
        "visible": true
      }
    ],
    "security": {
      "capabilities": []
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "© 2026 Lethe",
    "category": "Video",
    "shortDescription": "Remove silence and filler from video recordings",
    "longDescription": "Lethe is a desktop video editor that automatically detects and removes silence from recordings. Features include timeline editing, auto-captions via Whisper, and non-destructive workflow.",
    "fileAssociations": [
      {
        "ext": ["lethe"],
        "name": "Lethe Project",
        "description": "Lethe video project file",
        "mimeType": "application/x-lethe-project",
        "role": "Editor"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English"],
        "headerImage": null,
        "sidebarImage": null
      }
    },
    "externalBin": []
  }
}
